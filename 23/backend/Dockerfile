# Берём официальный образ Node.js 18 на базе Alpine Linux (очень лёгкий, ~5 МБ)
FROM node:18-alpine

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Сначала копируем ТОЛЬКО package.json — это важный трюк:
# Docker кэширует слои, и если код изменился, но зависимости нет —
# npm install не будет запускаться заново, что ускоряет сборку
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install

# Теперь копируем весь остальной код
COPY . .

# Документируем что приложение слушает на порту 3000
# (сам по себе порт не открывает — это делается в docker-compose.yml)
EXPOSE 3000

# Команда запуска контейнера
CMD ["npm", "start"]